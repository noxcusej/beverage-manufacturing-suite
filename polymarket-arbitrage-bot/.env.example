# =============================================================================
# Polymarket Arbitrage Bot Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- Polymarket CLOB API Credentials ---
# Generate API keys at: https://polymarket.com (Settings > API Keys)
# You need: API Key, API Secret, API Passphrase
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# --- Wallet Configuration ---
# Private key for the wallet used to sign/execute trades
# NEVER commit this value. Use a dedicated trading wallet with limited funds.
PRIVATE_KEY=

# --- Network Configuration ---
# Chain ID: 137 for Polygon mainnet
CHAIN_ID=137

# --- Trading Mode ---
# "paper" = simulated trades (no real money), "live" = real execution
TRADING_MODE=paper

# --- Arbitrage Parameters ---
# Minimum spread (after fees) to trigger a trade, in basis points (100 = 1%)
MIN_SPREAD_BPS=50

# Maximum position size in USDC per single arbitrage trade
MAX_POSITION_USDC=50.0

# Maximum total exposure across all open positions in USDC
MAX_TOTAL_EXPOSURE_USDC=500.0

# Maximum number of concurrent open positions
MAX_OPEN_POSITIONS=10

# --- Fee Configuration ---
# Polymarket maker fee (currently 0% for makers)
MAKER_FEE_BPS=0
# Polymarket taker fee (currently ~1-2% depending on price)
TAKER_FEE_BPS=150

# --- Risk Controls ---
# Emergency stop-loss: halt all trading if portfolio drops below this USDC value
STOP_LOSS_USDC=100.0

# Maximum single trade slippage tolerance in basis points
MAX_SLIPPAGE_BPS=100

# Cool-down period between trades on the same market (seconds)
TRADE_COOLDOWN_SECONDS=30

# --- WebSocket Configuration ---
# Polymarket CLOB WebSocket endpoint
WS_ENDPOINT=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Reconnect attempts before giving up
WS_MAX_RECONNECT_ATTEMPTS=10

# --- Tailscale VPN ---
# Enable routing traffic through Tailscale exit node
TAILSCALE_ENABLED=false

# Tailscale exit node hostname or IP (e.g., "us-east-1" or specific node)
TAILSCALE_EXIT_NODE=

# --- Logging ---
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log file path (leave empty for stdout only)
LOG_FILE=logs/arb-bot.log
